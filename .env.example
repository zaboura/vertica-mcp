# =========================
# Vertica connection (REQUIRED)
# =========================
# Hostname or IP of the Vertica server
VERTICA_HOST=your-vertica-host
# Port (Vertica defaults to 5433)
VERTICA_PORT=5433
# Database name
VERTICA_DATABASE=your-db-name
# Credentials (used when VERTICA_AUTH_MODE=basic, the default)
VERTICA_USER=your-username
VERTICA_PASSWORD=your-password

# =========================
# Authentication mode (OPTIONAL — defaults to basic)
# =========================
# Choose one: basic | oauth | mtls | kerberos
# basic     — standard username + password (default, backward compatible)
# oauth     — OAuth 2.0 / JWT token (password-less)
# mtls      — Mutual TLS client certificate (password-less)
# kerberos  — Kerberos / GSSAPI (password-less, requires host keytab)
VERTICA_AUTH_MODE=basic

# OAuth 2.0 — required when VERTICA_AUTH_MODE=oauth
# VERTICA_OAUTH_TOKEN=your-jwt-or-access-token

# mTLS — required when VERTICA_AUTH_MODE=mtls
# Path to the PEM-encoded client certificate and private key
# VERTICA_SSL_CERT=/path/to/client.crt
# VERTICA_SSL_KEY=/path/to/client.key

# Kerberos — optional overrides when VERTICA_AUTH_MODE=kerberos
# VERTICA_KERBEROS_SERVICE=vertica      # service name in the SPN
# VERTICA_KERBEROS_HOST=               # leave blank to use VERTICA_HOST

# =========================
# Connection behavior (OPTIONAL)
# =========================
# Max concurrent connections in pool (default increased to 50 for production workloads)
VERTICA_CONNECTION_LIMIT=50
# Defer opening the first connection until needed (1=true, 0=false)
VERTICA_LAZY_INIT=1

# SSL/TLS options (also applies to mTLS mode above)
# Use SSL/TLS to connect (true/false)
VERTICA_SSL=false
# SECURITY: Server certificate must be trusted/valid in production
# CRITICAL: Cannot be disabled (false) when ENVIRONMENT=production
VERTICA_SSL_REJECT_UNAUTHORIZED=true

# =========================
# Query controls (OPTIONAL)
# =========================
# Query timeout in seconds (0 disables; server/driver limits may still apply)
VERTICA_QUERY_TIMEOUT=600
# Retry logic for transient errors
VERTICA_MAX_RETRIES=3
# Delay between retries in seconds (can be fractional like 0.1)
VERTICA_RETRY_DELAY=0.1
# Cache TTL for metadata/describe operations (seconds)
VERTICA_CACHE_TTL=300
# Hard result size cap (MiB) to protect memory/egress
VERTICA_MAX_RESULT_MB=100
# Per-minute rate limit for requests (0 disables)
VERTICA_RATE_LIMIT=60
# Health check interval (seconds)
VERTICA_HEALTH_CHECK_INTERVAL=60

# =========================
# Operation permissions (OPTIONAL; safest defaults)
# =========================
# Global toggles
ALLOW_INSERT_OPERATION=false
ALLOW_UPDATE_OPERATION=false
ALLOW_DELETE_OPERATION=false
ALLOW_DDL_OPERATION=false

# Per-schema overrides: comma-separated "schema:true|false" pairs
# Example: public:true,analytics:false
SCHEMA_INSERT_PERMISSIONS=public:false
SCHEMA_UPDATE_PERMISSIONS=public:false
SCHEMA_DELETE_PERMISSIONS=public:false
SCHEMA_DDL_PERMISSIONS=public:false

# =========================
# Server / transport (OVERRIDABLE AT RUNTIME)
# =========================
# stdio | http | sse  (your entrypoint may override this per service)
TRANSPORT=http
# Listen address: use 0.0.0.0 for Docker, 127.0.0.1 for local dev
BIND=127.0.0.1
PORT=8000
# HTTP path prefix (for http transport only)
HTTP_PATH=/mcp

# =========================
# Diagnostics (OPTIONAL)
# =========================
# Set to 1 to bypass DB credential check in entrypoint (for demos only)
SKIP_DB_CHECK=0
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# =========================
# MCP Server Security (REQUIRED for production)
# =========================
# CRITICAL: Server will refuse to start without authentication configured
# Choose ONE of the following authentication methods:

# Option 1: API Key Authentication (simpler)
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=your-strong-random-api-key-here

# Option 2: JWT Authentication (enterprise)
# To validate JWTs issued by an external Identity Provider (e.g. Auth0, Keycloak)
# Both JWT_ISSUER and JWT_AUDIENCE must be set together
# JWT_ISSUER=https://your-tenant.auth0.com/
# JWT_AUDIENCE=your-api-audience

# ENVIRONMENT: Used for security checks (production | development | staging)
# In production mode:
# - SSL certificate bypass is forbidden
# - Authentication is strictly enforced
ENVIRONMENT=production

# CORS Configuration for HTTP/SSE endpoints
# SECURITY: Comma-separated list of allowed origins (NO WILDCARDS in production)
# CRITICAL: Using "*" with credentials enabled is FORBIDDEN and will cause startup failure
# Example: MCP_CORS_ORIGINS=https://app1.example.com,https://app2.example.com
# Leave empty to block all cross-origin requests (safest default)
MCP_CORS_ORIGINS=
